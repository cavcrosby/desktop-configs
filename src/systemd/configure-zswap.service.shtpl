[Unit]
Description=Configure the zswap kernel module
After=systemd-modules-load.service
OnFailure=notify-send-system@configure-zswap.service

[Service]
Type=oneshot
ExecStart=/bin/sh -c '\
    echo ${MAX_POOL_PERCENT} > "/sys/module/zswap/parameters/max_pool_percent"; \
    echo "zstd" > "/sys/module/zswap/parameters/compressor"; \
    echo 1 > "/sys/module/zswap/parameters/shrinker_enabled"; \
    echo 1 > "/sys/module/zswap/parameters/enabled"; \
'

[Install]
WantedBy=multi-user.target
